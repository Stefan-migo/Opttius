# Notion MCP Server Configuration
# Copy this file to .env and fill in your actual values

# ===== NOTION INTEGRATION =====
# Get your Notion Internal Integration Token from:
# https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxx

# ===== NOTION DATABASE IDs =====
# Create databases in your Notion workspace and copy their IDs
# Database IDs can be found in the URL:
# https://www.notion.so/workspace/{database-id}?v={view-id}
NOTION_DATABASE_DOCS=xxxxxx
NOTION_DATABASE_TASKS=xxxxxx
NOTION_DATABASE_FEATURES=xxxxxx

# ===== OPTIONAL CONFIGURATION =====
# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Server port (if running as HTTP server)
PORT=3001

# ===== NOTES =====
# 1. Make sure your Notion integration is shared with the pages/databases
# 2. Database IDs are 32-character hexadecimal strings
# 3. Never commit actual credentials to version control