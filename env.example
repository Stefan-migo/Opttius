# Opttius - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ===== NEXT.JS =====
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== SUPABASE =====
# For local development, use: http://127.0.0.1:54321
# Get your local keys by running: npm run supabase:status
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# For local Supabase: Get from 'npm run supabase:status' (service_role key)
# For production: Get from Supabase dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===== FLOW (Chile) =====
FLOW_API_KEY=your_flow_api_key
FLOW_SECRET_KEY=your_flow_secret_key
# Sandbox (pruebas)
FLOW_SANDBOX_MODE=false
FLOW_API_KEY_SANDBOX=your_flow_sandbox_api_key
FLOW_SECRET_KEY_SANDBOX=your_flow_sandbox_secret_key

# ===== MERCADO PAGO =====
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key
# Access token (producción). El código acepta MERCADOPAGO_ACCESS_TOKEN o MP_ACCESS_TOKEN
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token
MERCADOPAGO_WEBHOOK_SECRET=your_mercadopago_webhook_secret
# Sandbox (usar credenciales de prueba del panel MP)
MERCADOPAGO_SANDBOX_MODE=false
# Token de prueba. El código acepta MP_ACCESS_TOKEN_SANDBOX o MERCADOPAGO_ACCESS_TOKEN_SANDBOX
MP_ACCESS_TOKEN_SANDBOX=your_mercadopago_test_access_token
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY_SANDBOX=your_mercadopago_test_public_key
# URL base (para webhooks y back_urls de Mercado Pago, Flow, PayPal)
# IMPORTANTE: En desarrollo local, Mercado Pago NO puede llamar webhooks a localhost.
# Para pruebas con webhook y auto-retorno: ejecuta "npm run tunnel" (ngrok) y usa la URL HTTPS,
# ej. NEXT_PUBLIC_BASE_URL=https://abc123.ngrok-free.app
# El flujo embebido (CardPayment Brick) funciona con localhost; el redirect flow requiere HTTPS público.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ngrok: token para npm run tunnel (obtener en https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your_ngrok_authtoken

# ===== NOWPAYMENTS (Crypto Payments) =====
# Get your API keys from https://nowpayments.io/
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
# Sandbox mode for testing
NOWPAYMENTS_SANDBOX_MODE=true
NOWPAYMENTS_SANDBOX_API_KEY=your_nowpayments_sandbox_api_key

# ===== PAYPAL =====
# Get your credentials from https://developer.paypal.com/
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# Use sandbox URL for testing: https://api-m.sandbox.paypal.com
# Use production URL for live: https://api-m.paypal.com
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com

# ===== DEMO (solo desarrollo local) =====
# Usado por scripts/create-demo-super-admin.js y guías de demo. No usar en producción.
DEMO_ADMIN_EMAIL=your-demo-admin@example.com
DEMO_ADMIN_PASSWORD=your-secure-demo-password
# Opcional: fallback para /acceso-opticas?key=<valor>. Con tokens dinámicos (Config SaaS) no es obligatorio.
# Si usas tokens dinámicos, genera enlaces desde Config > Acceso ópticas conocidas.
# Generar con: node -e "console.log('opttius_demo_' + require('crypto').randomBytes(16).toString('hex'))"
DEMO_OPTICAS_ACCESS_KEY=

# ===== CRON (Vercel / jobs programados) =====
# Secret para autorizar llamadas a rutas /api/cron/* (backups, cleanup-expired-demos, etc.)
CRON_SECRET=your_cron_secret

# ===== RESEND (Email) =====
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@opttius.cl
# Webhook: configure https://your-domain.com/api/webhooks/resend in Resend Dashboard
# SAAS Trial ending cron: days before trial end to send reminder (default: 3)
SAAS_TRIAL_ENDING_DAYS_BEFORE=3

# ===== SANITY CMS =====
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=your_sanity_api_read_token
SANITY_WEBHOOK_SECRET=your_sanity_webhook_secret_for_revalidation

# ===== CLOUDINARY (Optional) =====
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== SECURITY =====
NEXTAUTH_SECRET=your_nextauth_secret_key
NEXTAUTH_URL=http://localhost:3000

# ===== ANALYTICS (Optional) =====
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_google_analytics_id

# ===== AI / LLM PROVIDERS =====
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4-turbo-preview
AI_FALLBACK_PROVIDERS=deepseek,google

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4-turbo-preview

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-3-sonnet-20240229

# Google (Gemini)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_DEFAULT_MODEL=gemini-pro

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ===== WHATSAPP (Meta Cloud API) =====
# B2B: Notificaciones Opttius → dueño. B2C: Webhook + Agent IA.
# Obtener en https://developers.facebook.com/ > App > WhatsApp > Cloud API
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
# Embedded Signup: App ID de Meta (público, para OAuth redirect)
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
# App Secret (solo servidor, para intercambiar code por token)
META_APP_SECRET=your_meta_app_secret
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
# String secreto para verificación GET del webhook (Meta)
WHATSAPP_VERIFY_TOKEN=your_verify_token
# Para validar firma X-Hub-Signature-256 en POST (OBLIGATORIO en producción)
WHATSAPP_APP_SECRET=your_app_secret

# ===== CLOUDFLARE R2 (Object Storage - imágenes) =====
# Si no se configuran, el upload fallback a Supabase Storage
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=opttius-images
R2_REGION=auto
# URL pública del bucket (tras configurar dominio público o R2 dev subdomain)
# Ejemplo dev: https://pub-xxx.r2.dev
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxx.r2.dev